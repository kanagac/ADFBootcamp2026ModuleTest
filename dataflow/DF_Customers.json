{
	"name": "DF_Customers",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_Customers",
						"type": "DatasetReference"
					},
					"name": "STGCustomers"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Sink_SQL_Tables",
						"type": "DatasetReference"
					},
					"name": "DIMCustomer"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          customer_id as integer,",
				"          customer_name as string,",
				"          email as string,",
				"          country as string,",
				"          created_date as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> STGCustomers",
				"STGCustomers derive(contact = concat(customer_name,'-', email)) ~> derivedColumn1",
				"derivedColumn2 alterRow(upsertIf(1==1)) ~> alterRow1",
				"derivedColumn1 derive(Continent = ERROR_FUNCTION('case (__NEW_LINE_R____NEW_LINE_N__    country=__SINGLE_QUOTE__Australia__SINGLE_QUOTE__, __SINGLE_QUOTE__Australia__SINGLE_QUOTE____NEW_LINE_R____NEW_LINE_N__    country=__SINGLE_QUOTE__India__SINGLE_QUOTE__, __SINGLE_QUOTE__Asia__SINGLE_QUOTE____NEW_LINE_R____NEW_LINE_N__    country in(__SINGLE_QUOTE__United Kingdom__SINGLE_QUOTE__,__SINGLE_QUOTE__Germany__SINGLE_QUOTE__) ,__SINGLE_QUOTE__Europe__SINGLE_QUOTE____NEW_LINE_R____NEW_LINE_N__    country in(__SINGLE_QUOTE__Canada__SINGLE_QUOTE__,__SINGLE_QUOTE__United States__SINGLE_QUOTE__) , __SINGLE_QUOTE__North America__SINGLE_QUOTE____NEW_LINE_R____NEW_LINE_N__)__NEW_LINE_R____NEW_LINE_N__'),",
				"          dw_created_at = currentDate()) ~> derivedColumn2",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['customer_id'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          customer_id,",
				"          customer_name,",
				"          email,",
				"          country,",
				"          created_date,",
				"          contact",
				"     )) ~> DIMCustomer"
			]
		}
	}
}