{
	"name": "DF_JOIN",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "SOURCEProducts"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "SORUCEOrders"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "SOURCEPayments"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "SinkFact"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "SinkFact1"
				}
			],
			"transformations": [
				{
					"name": "InnerJoin"
				},
				{
					"name": "Join"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SOURCEProducts",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SORUCEOrders",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SOURCEPayments",
				"SOURCEProducts, SORUCEOrders join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> InnerJoin",
				"SOURCEPayments, SORUCEOrders join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> Join",
				"InnerJoin sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> SinkFact",
				"Join sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> SinkFact1"
			]
		}
	}
}