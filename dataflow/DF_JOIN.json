{
	"name": "DF_JOIN",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "STGOrderItems"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "STGOrders"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "SOURCEPayments"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "SinkFact"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_WEEKLY_TEST",
						"type": "DatasetReference"
					},
					"name": "SinkFact1"
				}
			],
			"transformations": [
				{
					"name": "InnerJoin"
				},
				{
					"name": "Join"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> STGOrderItems",
				"source(output(",
				"          order_id as string,",
				"          customer_id as string,",
				"          order_date as string,",
				"          order_status as string,",
				"          order_amount as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> STGOrders",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SOURCEPayments",
				"STGOrderItems, STGOrders join(product_id == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> InnerJoin",
				"SOURCEPayments, STGOrders join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> Join",
				"InnerJoin sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> SinkFact",
				"Join sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> SinkFact1"
			]
		}
	}
}