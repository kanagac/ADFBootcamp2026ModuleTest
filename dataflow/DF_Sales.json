{
	"name": "DF_Sales",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Sink_SQL_Tables",
						"type": "DatasetReference"
					},
					"name": "dimProducts"
				},
				{
					"dataset": {
						"referenceName": "DS_Sink_SQL_Tables",
						"type": "DatasetReference"
					},
					"name": "dimcustomers"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_Orders",
						"type": "DatasetReference"
					},
					"name": "dimorders"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_Payments",
						"type": "DatasetReference"
					},
					"name": "dimpayments"
				},
				{
					"dataset": {
						"referenceName": "DS_Order_Items",
						"type": "DatasetReference"
					},
					"name": "OrderItem"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "join3"
				},
				{
					"name": "join4"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimProducts",
				"source(output(",
				"          customer_id as integer,",
				"          customer_name as string,",
				"          email as string,",
				"          contact as string,",
				"          Continent as string,",
				"          country as string,",
				"          created_date as timestamp,",
				"          dw_created_at as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimcustomers",
				"source(output(",
				"          order_id as integer,",
				"          customer_id as integer,",
				"          order_date as date,",
				"          order_status as string,",
				"          order_amount as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimorders",
				"source(output(",
				"          payment_id as integer,",
				"          order_id as integer,",
				"          payment_mode as string,",
				"          payment_status as string,",
				"          payment_date as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimpayments",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> OrderItem",
				"dimProducts, OrderItem join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"dimcustomers, dimorders join(dimcustomers@customer_id == dimorders@customer_id,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"dimpayments, dimorders join(dimpayments@order_id == dimorders@order_id,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"OrderItem, dimorders join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join4",
				"dimorders filter(iif(order_status=='Shipped'&&order_status=='Delivered')) ~> filter1"
			]
		}
	}
}