{
	"name": "Customer",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_sql_common",
						"type": "DatasetReference"
					},
					"name": "source"
				},
				{
					"dataset": {
						"referenceName": "DS_sql_common",
						"type": "DatasetReference"
					},
					"name": "Target"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_sql_common",
						"type": "DatasetReference"
					},
					"name": "Updated"
				},
				{
					"dataset": {
						"referenceName": "DS_sql_common",
						"type": "DatasetReference"
					},
					"name": "New"
				},
				{
					"dataset": {
						"referenceName": "DS_sql_common",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "SyncSources"
				},
				{
					"name": "split1"
				},
				{
					"name": "upsert"
				},
				{
					"name": "Transformations"
				}
			],
			"scriptLines": [
				"source(output(",
				"          customer_id as string,",
				"          customer_name as string,",
				"          email as string,",
				"          country as string,",
				"          created_date as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source",
				"source(output(",
				"          customer_id as integer,",
				"          customer_name as string,",
				"          email as string,",
				"          Contact as string,",
				"          Continent as string,",
				"          Country as string,",
				"          Created_Date as timestamp,",
				"          Dw_create_date as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> Target",
				"Transformations, Target join(Transformations@email == Target@email,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> SyncSources",
				"SyncSources split(isNull(Target@customer_id),",
				"     isNull(Target@email),",
				"     disjoint: false) ~> split1@(FindIfNull, Email, ToUpdate)",
				"split1@ToUpdate alterRow(updateIf(true())) ~> upsert",
				"source derive(Contact = concat(customer_name +'-' + email),",
				"          Continent = iif(country == 'Australia', 'Australia',\r",
				"iif(country == 'India', 'Asia',\r",
				"iif(country == 'United Kingdom','Europe',\r",
				"iif(country == 'Germany', 'Europe',\r",
				"iif(country == 'Canada','North America',\r",
				"iif(country == 'United States', 'North America', 'Not_Defined'))))))\r",
				",",
				"          country_ = iif(country == 'USA', 'United States of America', iif(country == 'UK', 'United Kingdom', country)),",
				"          dw_created_at = currentTimestamp(),",
				"          each(match(true()), $$ = iif(isNull($$), '', $$))) ~> Transformations",
				"upsert sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> Updated",
				"split1@FindIfNull sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> New",
				"split1@Email sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}