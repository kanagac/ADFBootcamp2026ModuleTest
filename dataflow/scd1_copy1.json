{
	"name": "scd1_copy1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_sql_common",
						"type": "DatasetReference"
					},
					"name": "source"
				},
				{
					"dataset": {
						"referenceName": "DS_sql_common",
						"type": "DatasetReference"
					},
					"name": "Target"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_sql_common",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DS_sql_common",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "SyncSources"
				},
				{
					"name": "split1"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          customer_id as string,",
				"          customer_name as string,",
				"          email as string,",
				"          country as string,",
				"          created_date as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> Target",
				"derivedColumn1, Target join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> SyncSources",
				"SyncSources split(isNull({}),",
				"     disjoint: false) ~> split1@(FindIfNull, ToUpdate)",
				"split1@ToUpdate alterRow(updateIf(true())) ~> alterRow1",
				"source derive(Contact = concat(customer_name +'-' + email),",
				"          Continent = ERROR_FUNCTION('replace(iif(country == __SINGLE_QUOTE__Australia__SINGLE_QUOTE__, __SINGLE_QUOTE__Australia__SINGLE_QUOTE__,__NEW_LINE_R____NEW_LINE_N__iif(country == __SINGLE_QUOTE__India__SINGLE_QUOTE__, __SINGLE_QUOTE__Asia__SINGLE_QUOTE__,__NEW_LINE_R____NEW_LINE_N__iif(country in (__SINGLE_QUOTE__United Kingdom__SINGLE_QUOTE__,__SINGLE_QUOTE__Germany__SINGLE_QUOTE__), __SINGLE_QUOTE__Europe__SINGLE_QUOTE__,__NEW_LINE_R____NEW_LINE_N__iif(country in (__SINGLE_QUOTE__Canada__SINGLE_QUOTE__,__SINGLE_QUOTE__United States__SINGLE_QUOTE__), __SINGLE_QUOTE__North America__SINGLE_QUOTE__, null)))))'),",
				"          country = iif(country == 'USA', 'United States of America', iif(country == 'UK', 'United Kingdom', country)),",
				"          dw_created_at = currentTimestamp(),",
				"          each(match(), ERROR_FUNCTION('') = ERROR_FUNCTION(''))) ~> derivedColumn1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"split1@FindIfNull sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink2"
			]
		}
	}
}