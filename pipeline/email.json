{
	"name": "email",
	"properties": {
		"activities": [
			{
				"name": "ForEach1",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "Get_name",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('Get_name').output.itemName",
						"type": "Expression"
					},
					"isSequential": true,
					"activities": [
						{
							"name": "segeregate_columns",
							"type": "Switch",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"on": {
									"value": "iif(@item().itemName == 'Australia', 'Australia',\niif(@item().itemName == 'India', 'Asia',\niif(@item().itemName in ('United Kingdom','Germany'), 'Europe',\niif(@item().itemName in ('Canada','United States'), 'North America', null))))",
									"type": "Expression"
								},
								"cases": [
									{
										"value": "email"
									},
									{
										"value": "Continent"
									},
									{
										"value": "Country"
									},
									{
										"value": "created_date"
									}
								]
							}
						}
					]
				}
			},
			{
				"name": "Get_name",
				"type": "GetMetadata",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "DS_blob_dt_common",
						"type": "DatasetReference",
						"parameters": {
							"container": "input",
							"directory": "Module_IN1742",
							"filename": "Customers.csv"
						}
					},
					"fieldList": [
						"itemName"
					],
					"storeSettings": {
						"type": "AzureBlobStorageReadSettings",
						"recursive": true,
						"enablePartitionDiscovery": false
					},
					"formatSettings": {
						"type": "DelimitedTextReadSettings"
					}
				}
			},
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "ForEach1",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"enableStaging": false
				}
			}
		],
		"folder": {
			"name": "target"
		},
		"annotations": []
	}
}